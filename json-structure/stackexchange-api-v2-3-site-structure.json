{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "name": "Site",
  "description": "A Stack Exchange community site.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/stackexchange/refs/heads/main/json-structure/stackexchange-api-v2-3-site-structure.json",
  "type": "object",
  "properties": {
    "site_url": {
      "type": "uri",
      "example": "https://stackoverflow.com"
    },
    "api_site_parameter": {
      "type": "string",
      "example": "stackoverflow"
    },
    "name": {
      "type": "string",
      "example": "Stack Overflow"
    },
    "site_type": {
      "type": "string",
      "enum": [
        "main_site",
        "meta_site"
      ],
      "example": "main_site"
    },
    "audience": {
      "type": "string",
      "example": "professional and enthusiast programmers"
    },
    "icon_url": {
      "type": "uri"
    },
    "logo_url": {
      "type": "uri"
    },
    "favicon_url": {
      "type": "uri"
    },
    "launch_date": {
      "type": "int64",
      "example": 1221177600
    },
    "site_state": {
      "type": "string",
      "enum": [
        "normal",
        "closed_beta",
        "open_beta",
        "linked_meta"
      ],
      "example": "normal"
    },
    "styling": {
      "type": "object",
      "properties": {
        "link_color": {
          "type": "string"
        },
        "tag_foreground_color": {
          "type": "string"
        },
        "tag_background_color": {
          "type": "string"
        }
      }
    },
    "related_sites": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "site_url": {
            "type": "uri"
          },
          "relation": {
            "type": "string",
            "enum": [
              "parent",
              "meta",
              "chat"
            ]
          }
        }
      }
    },
    "markdown_extensions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}