{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InboxItem",
  "description": "An inbox item for the authenticated user.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/stackexchange/refs/heads/main/json-schema/stackexchange-api-v2-3-inbox-item-schema.json",
  "type": "object",
  "properties": {
    "item_type": {
      "type": "string",
      "example": "comment"
    },
    "creation_date": {
      "type": "integer",
      "format": "int64"
    },
    "is_unread": {
      "type": "boolean"
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "link": {
      "type": "string",
      "format": "uri"
    },
    "question_id": {
      "type": "integer"
    },
    "answer_id": {
      "type": "integer"
    },
    "comment_id": {
      "type": "integer"
    },
    "site": {
      "type": "object",
      "description": "A Stack Exchange community site.",
      "properties": {
        "site_url": {
          "type": "string",
          "format": "uri",
          "example": "https://stackoverflow.com"
        },
        "api_site_parameter": {
          "type": "string",
          "example": "stackoverflow"
        },
        "name": {
          "type": "string",
          "example": "Stack Overflow"
        },
        "site_type": {
          "type": "string",
          "enum": [
            "main_site",
            "meta_site"
          ],
          "example": "main_site"
        },
        "audience": {
          "type": "string",
          "example": "professional and enthusiast programmers"
        },
        "icon_url": {
          "type": "string",
          "format": "uri"
        },
        "logo_url": {
          "type": "string",
          "format": "uri"
        },
        "favicon_url": {
          "type": "string",
          "format": "uri"
        },
        "launch_date": {
          "type": "integer",
          "format": "int64",
          "example": 1221177600
        },
        "site_state": {
          "type": "string",
          "enum": [
            "normal",
            "closed_beta",
            "open_beta",
            "linked_meta"
          ],
          "example": "normal"
        },
        "styling": {
          "type": "object",
          "properties": {
            "link_color": {
              "type": "string"
            },
            "tag_foreground_color": {
              "type": "string"
            },
            "tag_background_color": {
              "type": "string"
            }
          }
        },
        "related_sites": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "site_url": {
                "type": "string",
                "format": "uri"
              },
              "relation": {
                "type": "string",
                "enum": [
                  "parent",
                  "meta",
                  "chat"
                ]
              }
            }
          }
        },
        "markdown_extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}