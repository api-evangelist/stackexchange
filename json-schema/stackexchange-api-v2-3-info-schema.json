{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Info",
  "description": "Site-wide totals and metadata.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/stackexchange/refs/heads/main/json-schema/stackexchange-api-v2-3-info-schema.json",
  "type": "object",
  "properties": {
    "total_questions": {
      "type": "integer"
    },
    "total_unanswered": {
      "type": "integer"
    },
    "total_accepted": {
      "type": "integer"
    },
    "total_answers": {
      "type": "integer"
    },
    "total_comments": {
      "type": "integer"
    },
    "total_votes": {
      "type": "integer"
    },
    "total_badges": {
      "type": "integer"
    },
    "total_users": {
      "type": "integer"
    },
    "questions_per_minute": {
      "type": "number"
    },
    "answers_per_minute": {
      "type": "number"
    },
    "badges_per_minute": {
      "type": "number"
    },
    "new_active_users": {
      "type": "integer"
    },
    "api_revision": {
      "type": "string",
      "example": "2024.12.01.1234"
    },
    "site": {
      "type": "object",
      "description": "A Stack Exchange community site.",
      "properties": {
        "site_url": {
          "type": "string",
          "format": "uri",
          "example": "https://stackoverflow.com"
        },
        "api_site_parameter": {
          "type": "string",
          "example": "stackoverflow"
        },
        "name": {
          "type": "string",
          "example": "Stack Overflow"
        },
        "site_type": {
          "type": "string",
          "enum": [
            "main_site",
            "meta_site"
          ],
          "example": "main_site"
        },
        "audience": {
          "type": "string",
          "example": "professional and enthusiast programmers"
        },
        "icon_url": {
          "type": "string",
          "format": "uri"
        },
        "logo_url": {
          "type": "string",
          "format": "uri"
        },
        "favicon_url": {
          "type": "string",
          "format": "uri"
        },
        "launch_date": {
          "type": "integer",
          "format": "int64",
          "example": 1221177600
        },
        "site_state": {
          "type": "string",
          "enum": [
            "normal",
            "closed_beta",
            "open_beta",
            "linked_meta"
          ],
          "example": "normal"
        },
        "styling": {
          "type": "object",
          "properties": {
            "link_color": {
              "type": "string"
            },
            "tag_foreground_color": {
              "type": "string"
            },
            "tag_background_color": {
              "type": "string"
            }
          }
        },
        "related_sites": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "site_url": {
                "type": "string",
                "format": "uri"
              },
              "relation": {
                "type": "string",
                "enum": [
                  "parent",
                  "meta",
                  "chat"
                ]
              }
            }
          }
        },
        "markdown_extensions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}